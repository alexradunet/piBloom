[Unit]
Description=NixPI Signal CLI Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=forking
WorkingDirectory=@BASE@
Environment=PATH=/run/current-system/sw/bin
Environment=PI_GATEWAY_STATE_DIR=@STATE_DIR@
Environment=SIGNAL_GATEWAY_STATE_DIR=@STATE_DIR@
Environment=PI_GATEWAY_CONFIG=@CONFIG@
Environment=SIGNAL_GATEWAY_CONFIG=@CONFIG@
Environment=SIGNAL_CLI_BIN=@SIGNAL_CLI_BIN@
PIDFile=@STATE_DIR@/tmp/signal-daemon.pid
ExecStart=@BASE@/bin/start-signal-daemon
ExecStop=@BASE@/bin/stop-signal-daemon
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target
