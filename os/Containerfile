# Bloom OS — Fedora bootc 42 with Pi coding agent
# Build: podman build -f os/Containerfile -t bloom-os:latest .
# Install: sudo bootc install to-disk /dev/sdX --source-imgref containers-storage:bloom-os:latest
FROM quay.io/fedora/fedora-bootc:42

# System packages
RUN dnf install -y \
    podman \
    nodejs \
    npm \
    git \
    gh \
    syncthing \
    ripgrep \
    fd-find \
    jq \
    curl \
    && dnf clean all \
    && rm -rf /var/cache/libdnf5 /var/lib/dnf /var/log/dnf5.log /var/log/dnf.log /var/cache/ldconfig/aux-cache

# Install oras CLI for OCI artifact management
RUN curl -LO https://github.com/oras-project/oras/releases/download/v1.2.2/oras_1.2.2_linux_amd64.tar.gz && \
    tar xzf oras_*.tar.gz -C /usr/local/bin oras && \
    rm oras_*.tar.gz

# Create bloom system user via systemd-sysusers
COPY os/sysconfig/bloom-sysusers.conf /usr/lib/sysusers.d/bloom.conf
RUN systemd-sysusers

# Install Pi coding agent globally (keep npm cache out of /var for bootc lint)
RUN HOME=/tmp npm install -g --cache /tmp/npm-cache @mariozechner/pi-coding-agent && \
    rm -rf /tmp/npm-cache /var/roothome/.npm /root/.npm

# Install Bloom Pi package
COPY . /usr/local/share/bloom/
RUN cd /usr/local/share/bloom && HOME=/tmp npm install --omit=dev --cache /tmp/npm-cache && \
    rm -rf /tmp/npm-cache /var/roothome/.npm /root/.npm

# Configure Pi settings defaults in /usr (immutable layer)
RUN mkdir -p /usr/local/share/bloom/.pi/agent && \
    echo '{"packages": ["/usr/local/share/bloom"]}' > /usr/local/share/bloom/.pi/agent/settings.json

# Shell config skel in /usr (immutable layer)
COPY os/sysconfig/bloom-bashrc /usr/local/share/bloom/skel/.bashrc
COPY os/sysconfig/bloom-bash_profile /usr/local/share/bloom/skel/.bash_profile

# tmpfiles.d for /var directory structure (created at boot)
COPY os/sysconfig/bloom-tmpfiles.conf /usr/lib/tmpfiles.d/bloom.conf

# Install persona files
RUN mkdir -p /usr/local/share/bloom/persona

# Systemd service for Pi auto-start on login
COPY os/sysconfig/bloom-greeting.sh /usr/local/bin/bloom-greeting.sh
RUN chmod +x /usr/local/bin/bloom-greeting.sh

# Syncthing user service
RUN systemctl enable syncthing@bloom.service

# Update check timer
COPY os/sysconfig/bloom-update-check.timer /usr/lib/systemd/system/bloom-update-check.timer
COPY os/sysconfig/bloom-update-check.service /usr/lib/systemd/system/bloom-update-check.service
COPY os/sysconfig/bloom-update-check.sh /usr/local/bin/bloom-update-check.sh
RUN chmod +x /usr/local/bin/bloom-update-check.sh
RUN systemctl enable bloom-update-check.timer

# bootc installation config
COPY os/bootc/config.toml /usr/lib/bootc/install/config.toml

# Labels
LABEL containers.bootc 1
LABEL com.github.containers.toolbox="false"
LABEL bloom.version="0.0.1"
LABEL description="Bloom — Pi-native AI companion OS"

# Validate bootc image (must be after all labels)
RUN bootc container lint
